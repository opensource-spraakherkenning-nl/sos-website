---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { base } from '../../lib/base';

export async function getStaticPaths() {
  const projecten = await getCollection('projecten');
  return projecten.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const d = project.data;
---

<BaseLayout title={d.title} description={d.beschrijving}>
  <div class="container">

    <div class="article-header">
      {d.logo && (
        <div class="project-logo">
          <img src={`${base}${d.logo}`} alt={`${d.title} logo`} />
        </div>
      )}
      <h1>{d.title}</h1>
      {d.instelling && <p class="project-instelling">{d.instelling}</p>}
      <p style="color: var(--color-text-muted); margin-top: 0.5rem;">{d.beschrijving}</p>

      <div class="card-tags" style="margin-top: 0.75rem;">
        {d.onderwerp.map(o => <span class="tag">{o}</span>)}
        {d.status === 'afgerond' && <span class="tag tag--muted">Afgerond</span>}
      </div>

      <dl class="project-meta">
        {d.looptijd     && <><dt>Looptijd</dt>    <dd>{d.looptijd}</dd></>}
        {d.financiering && <><dt>Financiering</dt><dd>
          <span>{d.financiering}</span>
          {d.fonds_logo && (
            <img src={`${base}${d.fonds_logo}`} alt={d.financiering} class="fonds-logo" />
          )}
        </dd></>}
        {d.contact      && <><dt>Contact</dt>     <dd>{d.contact_email
          ? <a href={`mailto:${d.contact_email}`}>{d.contact}</a>
          : d.contact
        }</dd></>}
        {d.website && <><dt>Website</dt><dd><a href={d.website} target="_blank" rel="noopener">{d.website}</a></dd></>}
        {d.github  && <><dt>GitHub</dt> <dd><a href={d.github}  target="_blank" rel="noopener">{d.github}</a></dd></>}
      </dl>
    </div>

    {d.partners && d.partners.length > 0 && (
      <section class="partners-sectie">
        <h2>Partners</h2>
        <div class="partners-lijst">
          {d.partners.map(p => (
            p.website ? (
              <a href={p.website} target="_blank" rel="noopener" class="partner-item">
                {p.logo
                  ? <img src={`${base}${p.logo}`} alt={p.naam} class="partner-logo" />
                  : <span class="partner-naam">{p.naam}</span>
                }
              </a>
            ) : (
              <div class="partner-item">
                {p.logo
                  ? <img src={`${base}${p.logo}`} alt={p.naam} class="partner-logo" />
                  : <span class="partner-naam">{p.naam}</span>
                }
              </div>
            )
          ))}
        </div>
      </section>
    )}

    <div class="article-body">
      <Content />
    </div>

    <p style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
      <a href={`${base}projecten`}>← Terug naar projecten</a>
    </p>

  </div>
</BaseLayout>

<style>
  .project-logo {
    margin-bottom: 1.5rem;
  }

  .project-logo img {
    max-height: 80px;
    max-width: 240px;
    object-fit: contain;
  }

  .project-instelling {
    font-size: 0.9rem;
    color: var(--color-accent);
    font-weight: 500;
    margin: 0.25rem 0 0;
  }

  .project-meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.35rem 1.5rem;
    margin-top: 1.5rem;
    font-size: 0.9rem;
    max-width: 560px;
  }

  .project-meta dt {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .project-meta dd {
    margin: 0;
  }

  .tag--muted {
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
  }

  .fonds-logo {
    display: block;
    max-height: 40px;
    max-width: 160px;
    object-fit: contain;
    margin-top: 0.5rem;
  }

  .partners-sectie {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .partners-sectie h2 {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-weight: 500;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .partners-lijst {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem 2rem;
  }

  .partner-item {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }

  .partner-logo {
    max-height: 48px;
    max-width: 140px;
    object-fit: contain;
    filter: grayscale(30%);
    transition: filter 0.15s;
  }

  .partner-item:hover .partner-logo {
    filter: grayscale(0%);
  }

  .partner-naam {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
  }
</style>
