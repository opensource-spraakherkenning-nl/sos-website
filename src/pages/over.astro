---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { base } from '../lib/base';

const bestuursleden = (await getCollection('bestuur'))
  .sort((a, b) => a.data.volgorde - b.data.volgorde);
---

<BaseLayout
  title="Over"
  description="Missie, visie, doelstellingen en activiteiten van Stichting Open Spraaktechnologie."
>
  <div class="container">

    <div class="page-header">
      <h1>Over de stichting</h1>
      <p>Stichting Open Spraaktechnologie werd opgericht op 10 mei 2019.</p>
    </div>

    <section class="section" id="missie">
      <h2>Missie</h2>
      <p>
        Wij stimuleren innovatie en samenwerking rond Nederlandse spraaktechnologie door:
      </p>
      <ul>
        <li>Het faciliteren van kennisuitwisseling tussen onderzoeksinstellingen, industrie, publieke organisaties en het algemene publiek, en het vergroten van het bewustzijn over ontwikkelingen, uitdagingen en successen in de Nederlandse spraaktechnologie.</li>
        <li>Het bevorderen van interdisciplinaire samenwerking binnen het spraaktechnologie-ecosysteem in Nederland.</li>
        <li>Het ondersteunen van verantwoorde ontwikkeling en toepassing van spraaktechnologie ten behoeve van Nederlandssprekende gemeenschappen.</li>
        <li>Te dienen als een betrouwbare, objectieve bron van informatie over Nederlandse spraaktechnologie in het publieke debat en bij beleidsvorming.</li>
      </ul>
    </section>

    <section class="section" id="visie">
      <h2>Visie</h2>
      <blockquote>
        De Stichting Open Spraaktechnologie is katalysator voor innovatie rond Nederlandse
        spraaktechnologie, en bevordert een levendig, samenwerkend ecosysteem waar kennis
        vrij stroomt tussen onderzoek, industrie en samenleving.
      </blockquote>
    </section>

    <section class="section" id="doelstellingen">
      <h2>Doelstellingen</h2>
      <div class="doelen-grid">
        <div class="doel-card">
          <h3>Kennisuitwisseling</h3>
          <p>Stimuleren van kennisoverdracht binnen en tussen gemeenschappen die geïnteresseerd zijn in Nederlandstalige spraaktechnologie — over de stand van zaken in onderzoek en over de wensen en behoeften binnen industrie en instellingen.</p>
        </div>
        <div class="doel-card">
          <h3>Interdisciplinaire samenwerking</h3>
          <p>Samenbrengen van verschillende communities die interesse hebben in spraaktechnologie om kennisoverdracht te bevorderen.</p>
        </div>
        <div class="doel-card">
          <h3>Verantwoorde ontwikkeling</h3>
          <p>Stimuleren van informatieontwikkeling over onderwerpen die relevant zijn voor de community:</p>
          <ul>
            <li>Kwaliteit Nederlandstalige spraakherkenning (benchmarking)</li>
            <li>Juridische, ethische en maatschappelijke vraagstukken</li>
            <li>Gebruik van NL spraaktechnologie</li>
          </ul>
        </div>
        <div class="doel-card">
          <h3>Betrouwbare informatiebron</h3>
          <p>De verschillende communities informeren over:</p>
          <ul>
            <li>De stand van zaken met betrekking tot Nederlandstalige spraaktechnologie</li>
            <li>Mogelijkheden voor subsidies gerelateerd aan R&amp;D rond spraaktechnologie</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section" id="activiteiten">
      <h2>Activiteiten</h2>
      <p>Onze activiteiten zijn gelinkt aan onze doelstellingen en gericht op verschillende doelgroepen.</p>

      <h3 style="margin-top: 1.5rem;">Huidige activiteiten</h3>
      <ul>
        <li>We organiseren jaarlijks een <a href={`${base}edities`}>Dutch Speech Tech Day</a></li>
        <li>We ondersteunen een jaarlijkse winter- of summerschool rond spraaktechnologie</li>
        <li>We organiseren site visits bij (onderzoeks)groepen die werken aan spraaktechnologie</li>
        <li>We houden mogelijkheden voor sponsoring en subsidie in de gaten en zetten calls uit in samenwerking met fondsen</li>
        <li>We stimuleren benchmarking voor Nederlandstalige spraaktechnologie</li>
        <li>We informeren doelgroepen over ontwikkelingen via LinkedIn en deze website</li>
      </ul>

      <h3 style="margin-top: 1.5rem;">Plannen</h3>
      <ul>
        <li>Publieksactiviteiten om kennis over (verantwoorde) inzet van spraaktechnologie te verspreiden</li>
        <li>Bijdragen aan de ontwikkeling van masterclasses en webinars over spraaktechnologie</li>
      </ul>
    </section>

    <section class="section" id="bestuur">
      <h2>Bestuur</h2>
      <p>Bestuursleden ontvangen geen vergoeding; gemaakte onkosten worden vergoed.</p>

      <div class="bestuur-grid">
        {bestuursleden.map(async (lid) => {
          const { Content } = await lid.render();
          return (
            <div class="bestuur-card">
              {lid.data.foto && (
                <img
                  src={`${base}${lid.data.foto.replace(/^\//, '')}`}
                  alt={lid.data.naam}
                  class="bestuur-foto"
                />
              )}
              <div class="bestuur-info">
                <p class="post-meta">{lid.data.rol}</p>
                <h3>{lid.data.naam}</h3>
                <div class="bestuur-beschrijving">
                  <Content />
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="section" id="anbi">
      <h2>ANBI-gegevens</h2>
      <p>Stichting Open Spraaktechnologie heeft ANBI-status sinds 20 mei 2020.</p>
      <table style="border-collapse: collapse; width: 100%; max-width: 560px; margin-top: 1rem;">
        <tbody>
          {[
            ['Naam',             'Stichting Open Spraaktechnologie'],
            ['RSIN',             '860031354'],
            ['KvK',              '74801260'],
            ['Opgericht',        '10 mei 2019'],
            ['ANBI-status',      'Verleend op 20 mei 2020'],
            ['Postadres',        'Zesakkers 2108, 6605 TG Wijchen'],
            ['Bezoekadres',      'Erasmusplein 1, 6525 HT Nijmegen'],
            ['Bank',             'NL28 TRIO 0379 687 216 (Triodos Bank)'],
            ['Contact',          'roeland.ordelman@utwente.nl'],
            ['Beloningsbeleid',  'Bestuursleden ontvangen geen vergoeding; onkosten worden vergoed.'],
            ['Financiering',     'Donaties'],
          ].map(([label, value]) => (
            <tr>
              <td style="padding: 0.4rem 1.5rem 0.4rem 0; color: var(--color-text-muted); white-space: nowrap; vertical-align: top;">{label}</td>
              <td style="padding: 0.4rem 0;">{value}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h3 style="margin-top: 2rem;">Jaarrekeningen</h3>
      <ul class="jaarrekeningen-lijst">
        {[
          ['2025', 'https://openspraaktechnologie.org/wp-content/uploads/2026/04/jaarrekening-2025-stg.-open-spraaktechnologie-getekend.pdf'],
          ['2024', 'https://openspraaktechnologie.org/wp-content/uploads/2025/04/jaarrekening-stg.-open-spraaktechnologie-2024.pdf'],
          ['2023', 'https://openspraaktechnologie.org/wp-content/uploads/2024/05/stichtingopenspraaktechnologie-jaarrekening2023-publicatie.pdf'],
          ['2022', 'https://openspraaktechnologie.org/wp-content/uploads/2023/05/stichting-open-spraaktechnologie-concept-jaarrekening-2022-publicatie.pdf'],
          ['2021', 'https://openspraaktechnologie.org/wp-content/uploads/2022/03/jaarrekening-2021-publicatie.pdf'],
          ['2020', 'https://openspraaktechnologie.org/wp-content/uploads/2021/03/jaarrekening-2020-publicatie.pdf'],
          ['2019', 'https://openspraaktechnologie.org/wp-content/uploads/2020/04/jaarrekening-2019-sos.pdf'],
        ].map(([jaar, url]) => (
          <li>
            <a href={url} target="_blank" rel="noopener">Jaarrekening {jaar}</a>
          </li>
        ))}
      </ul>
    </section>

    <section class="section" id="colofon">
      <h2>Colofon</h2>
      <p>
        Deze website is gebouwd met <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
        en wordt gehost op <a href="https://pages.github.com" target="_blank" rel="noopener">GitHub Pages</a>.
        De broncode is beschikbaar op
        <a href="https://github.com/roelandordelman/sos-website" target="_blank" rel="noopener">GitHub</a>.
      </p>
    </section>

  </div>
</BaseLayout>

<style>
  blockquote {
    border-left: 4px solid var(--color-accent);
    margin: 0;
    padding: 0.75rem 1.5rem;
    background: var(--color-bg-alt);
    border-radius: 0 6px 6px 0;
    font-size: 1.1rem;
    font-style: italic;
    color: var(--color-primary);
    line-height: 1.6;
  }

  .doelen-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-top: 1.25rem;
  }

  .doel-card {
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.35rem 1.5rem;
    background: var(--color-bg-alt);
  }

  .doel-card h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    color: var(--color-accent);
  }

  .doel-card p, .doel-card li {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .doel-card ul {
    margin-top: 0.5rem;
    margin-bottom: 0;
    padding-left: 1.25rem;
  }

  .bestuur-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 1.5rem;
  }

  .bestuur-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .bestuur-foto {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    flex-shrink: 0;
    border: 2px solid var(--color-border);
  }

  .bestuur-info h3 {
    margin-bottom: 0.25rem;
  }

  .bestuur-beschrijving p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .jaarrekeningen-lijst {
    list-style: none;
    padding: 0;
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }

  .jaarrekeningen-lijst li::before {
    content: "↓ ";
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .doelen-grid, .bestuur-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
